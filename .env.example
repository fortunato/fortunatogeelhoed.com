# Environment variables for the Hono backend.
#
# Every variable here is OPTIONAL: with none set, the site runs normally — the
# availability badge reads the public gist anonymously and telemetry simply isn't
# shipped. Copy this file to .env and fill in only what you need.

# --- Live availability badge -------------------------------------------------

# The gist read for the availability value. Defaults to the project's own gist,
# so you only set this to point at a different one.
# AVAILABILITY_GIST_ID=6b9e17e49b45c78833cc2b4a5ab0c771

# Optional GitHub token. The gist is read anonymously by default (60 requests/hr,
# which is ample behind the cache + conditional requests). A token only lifts that
# ceiling to 5000/hr; it is NOT required. A read-only / no-scope token is enough.
# GITHUB_TOKEN=

# Cache lifetime for the availability value, in milliseconds (default 120000).
# AVAILABILITY_TTL_MS=120000

# --- Backend logging (pino -> Grafana Cloud Loki) ----------------------------

# Log level (default: debug in dev, info in prod, silent under test).
# LOG_LEVEL=info

# Loki log shipping. All three are required to ship; absent any of them, the
# server logs to stdout only and is otherwise unaffected. Production only.
# LOKI_HOST=https://logs-prod-xxx.grafana.net
# LOKI_USER=123456
# LOKI_TOKEN=

# --- Frontend RUM (Grafana Faro, proxied through /api/rum) --------------------

# The Grafana Faro collector the backend forwards RUM to, and its app key. Both
# stay server-side (never shipped to the browser). Absent, /api/rum accepts and
# drops payloads.
# FARO_COLLECTOR_URL=https://faro-collector-prod-xxx.grafana.net/collect
# FARO_APP_KEY=


# --- Contact email delivery (AhaSend) ------------------------------------
#  AHASEND_API_KEY=
# AHASEND_ACCOUNT_ID=
# AHASEND_FROM_EMAIL=
# AHASEND_TO_EMAIL=
# AHASEND_FROM_NAME=
