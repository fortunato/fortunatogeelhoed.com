{
	"name": "fortunatogeelhoed.com",
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=22",
		"bun": ">=1.3"
	},
	"scripts": {
		"dev:react": "nx run-many -t dev -p react api",
		"dev:vue": "nx run-many -t dev -p vue api",
		"dev:angular": "nx run-many -t dev -p angular api",
		"dev:all": "nx run-many -t dev -p react vue angular api --parallel=4",
		"build:css": "bun run scripts/build-css.ts",
		"build:content": "bun run scripts/build-content.ts",
		"build": "bun run build:css && bun run build:content && nx run-many -t build -p react vue angular api && bun run scripts/rewrite-asset-urls.ts",
		"build:react": "nx run react:build",
		"build:vue": "nx run vue:build",
		"build:angular": "nx run angular:build",
		"start": "NODE_ENV=production bun run packages/api/src/index.ts",
		"lint": "biome check .",
		"lint:fix": "biome check --write ."
	},
	"dependencies": {
		"@angular/common": "^21.0.0",
		"@angular/compiler": "^21.0.0",
		"@angular/core": "^21.0.0",
		"@angular/platform-browser": "^21.0.0",
		"@angular/platform-server": "^21.0.0",
		"@angular/router": "^21.0.0",
		"@angular/ssr": "^21.2.13",
		"gray-matter": "^4.0.3",
		"hono": "^4.7.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"react-router": "^7.0.0",
		"vue": "^3.5.0",
		"vue-router": "^4.5.0",
		"zone.js": "^0.16.2"
	},
	"devDependencies": {
		"@analogjs/platform": "^1.14.0",
		"@analogjs/vite-plugin-angular": "^1.14.0",
		"@angular/animations": "^21.2.15",
		"@angular/build": "^21.2.13",
		"@angular/compiler-cli": "^21.2.15",
		"@biomejs/biome": "^1.9.0",
		"@nx/js": "^20.0.0",
		"@nx/vite": "^20.0.0",
		"@types/bun": "^1.3.14",
		"@vitejs/plugin-react": "^4.3.0",
		"@vitejs/plugin-vue": "^5.2.0",
		"nx": "^20.0.0",
		"typescript": "^5.7.0",
		"vite": "^6.0.0",
		"vite-ssg": "^0.24.0"
	}
}
