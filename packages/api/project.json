{
	"name": "api",
	"sourceRoot": "packages/api/src",
	"targets": {
		"dev": {
			"command": "bun run packages/api/src/index.ts"
		},
		"build": {
			"command": "bun build packages/api/src/index.ts --outdir dist/api --target bun"
		},
		"test": {
			"command": "vitest run --project node"
		},
		"lint": {
			"command": "biome check packages/api/"
		},
		"typecheck": {
			"command": "tsc --noEmit -p packages/api/tsconfig.json"
		}
	}
}
