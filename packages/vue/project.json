{
	"name": "vue",
	"sourceRoot": "packages/vue/src",
	"targets": {
		"dev": {
			"command": "vite --config packages/vue/vite.config.ts --port 5174"
		},
		"build": {
			"command": "vite-ssg build --config packages/vue/vite.config.ts"
		},
		"test": {
			"command": "vitest run --project browser-vue"
		},
		"lint": {
			"command": "biome check packages/vue/"
		},
		"typecheck": {
			"command": "vue-tsc --noEmit -p packages/vue/tsconfig.json"
		}
	}
}
