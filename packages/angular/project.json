{
	"name": "angular",
	"sourceRoot": "packages/angular/src",
	"targets": {
		"dev": {
			"command": "vite --config packages/angular/vite.config.ts --port 5175"
		},
		"build": {
			"command": "vite build --config packages/angular/vite.config.ts && vite build --config packages/angular/vite.config.ssr.ts && bun run packages/angular/prerender.ts"
		},
		"test": {
			"command": "vitest run --project browser-angular"
		},
		"lint": {
			"command": "biome check packages/angular/"
		},
		"typecheck": {
			"command": "ngc --noEmit -p packages/angular/tsconfig.json"
		}
	}
}
